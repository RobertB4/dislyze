{
	"name": "@dislyze/zoroark",
	"version": "0.1.0",
	"private": true,
	"description": "Shared UI component library for Dislyze projects",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build && npm run package",
		"preview": "vite preview",
		"package": "svelte-kit sync && svelte-package && npm run build:css",
		"build:css": "vite build --config vite.css.config.ts",
		"prepublishOnly": "npm run package",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint ."
	},
	"exports": {
		"./Alert": {
			"types": "./dist/Alert.svelte.d.ts",
			"svelte": "./dist/Alert.svelte"
		},
		"./Badge": {
			"types": "./dist/Badge.svelte.d.ts",
			"svelte": "./dist/Badge.svelte"
		},
		"./Button": {
			"types": "./dist/Button.svelte.d.ts",
			"svelte": "./dist/Button.svelte"
		},
		"./EmptyAvatar": {
			"types": "./dist/EmptyAvatar.svelte.d.ts",
			"svelte": "./dist/EmptyAvatar.svelte"
		},
		"./Input": {
			"types": "./dist/Input.svelte.d.ts",
			"svelte": "./dist/Input.svelte"
		},
		"./InteractivePill": {
			"types": "./dist/InteractivePill.svelte.d.ts",
			"svelte": "./dist/InteractivePill.svelte"
		},
		"./Select": {
			"types": "./dist/Select.svelte.d.ts",
			"svelte": "./dist/Select.svelte"
		},
		"./Slideover": {
			"types": "./dist/Slideover.svelte.d.ts",
			"svelte": "./dist/Slideover.svelte"
		},
		"./Spinner": {
			"types": "./dist/Spinner.svelte.d.ts",
			"svelte": "./dist/Spinner.svelte"
		},
		"./Toast": {
			"types": "./dist/Toast/Toast.svelte.d.ts",
			"svelte": "./dist/Toast/Toast.svelte"
		},
		"./ToastContainer": {
			"types": "./dist/Toast/ToastContainer.svelte.d.ts",
			"svelte": "./dist/Toast/ToastContainer.svelte"
		},
		"./Tooltip": {
			"types": "./dist/Tooltip.svelte.d.ts",
			"svelte": "./dist/Tooltip.svelte"
		},
		"./toast": {
			"types": "./dist/Toast/toast.d.ts",
			"default": "./dist/Toast/toast.js"
		},
		"./errors": {
			"types": "./dist/utils/errors.d.ts",
			"default": "./dist/utils/errors.js"
		},
		"./routing": {
			"types": "./dist/utils/routing.d.ts",
			"default": "./dist/utils/routing.js"
		},
		"./meCache": {
			"types": "./dist/utils/meCache.d.ts",
			"default": "./dist/utils/meCache.js"
		},
		"./assertNever": {
			"types": "./dist/utils/assertNever.d.ts",
			"default": "./dist/utils/assertNever.js"
		},
		"./styles.css": "./dist/app.css"
	},
	"files": [
		"dist",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*"
	],
	"peerDependencies": {
		"@sveltejs/kit": "^2.16.0",
		"svelte": "^5.34.2"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.0",
		"@eslint/js": "^10.0.0",
		"@sveltejs/adapter-auto": "^3.0.0",
		"@sveltejs/kit": "^2.16.0",
		"@sveltejs/package": "^2.0.0",
		"@sveltejs/vite-plugin-svelte": "^5.0.0",
		"@tailwindcss/vite": "^4.0.17",
		"@types/eslint": "^9.6.0",
		"eslint": "^10.0.0",
		"eslint-config-prettier": "^10.0.1",
		"eslint-plugin-svelte": "^3.0.0",
		"globals": "^16.0.0",
		"prettier": "^3.4.2",
		"prettier-plugin-svelte": "^3.3.3",
		"publint": "^0.3.17",
		"svelte": "^5.0.0",
		"svelte-check": "^4.0.0",
		"tailwindcss": "^4.0.17",
		"typescript": "^5.0.0",
		"typescript-eslint": "^8.20.0",
		"vite": "^6.0.0"
	},
	"sideEffects": [
		"**/*.css"
	],
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts"
}
