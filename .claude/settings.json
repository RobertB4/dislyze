{
  "permissions": {
    "allow": ["Bash(playwright-cli:*)", "Bash(npx playwright-cli:*)"],
    "deny": [
      "Read(**/.env.sensitive)",
      "Read(//**/.env.sensitive)",
      "Bash(git push --force*main*)",
      "Bash(git push*--force*main*)",
      "Bash(git push -f*main*)",
      "Bash(git push*-f*main*)",
      "Bash(git push --force-with-lease*main*)",
      "Bash(git push*--force-with-lease*main*)",
      "Bash(git push*+main*)",
      "Bash(git push*+HEAD:main*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/dependency-awareness.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
