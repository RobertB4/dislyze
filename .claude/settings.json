{
  "permissions": {
    "allow": ["Bash(playwright-cli:*)", "Bash(npx playwright-cli:*)"],
    "deny": [
      "Read(**/.env.sensitive)",
      "Read(//**/.env.sensitive)",
      "Bash(git push --force*main*)",
      "Bash(git push*--force*main*)",
      "Bash(git push -f*main*)",
      "Bash(git push*-f*main*)",
      "Bash(git push --force-with-lease*main*)",
      "Bash(git push*--force-with-lease*main*)",
      "Bash(git push*+main*)",
      "Bash(git push*+HEAD:main*)"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/prompt-context.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/dependency-awareness.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/duplication-radar.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/pattern-guide.sh",
            "timeout": 10
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/periodic-review.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/pre-compaction.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/post-compaction.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
