{
  "name": "dislyze",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {}
  },
  "workspaceFolder": "/workspace",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=cached",
  "mounts": [
    "source=dislyze-zoroark-nm,target=/workspace/zoroark/node_modules,type=volume",
    "source=dislyze-lugia-fe-nm,target=/workspace/lugia-frontend/node_modules,type=volume",
    "source=dislyze-giratina-fe-nm,target=/workspace/giratina-frontend/node_modules,type=volume",
    "source=dislyze-sendgrid-nm,target=/workspace/sendgrid-mock/node_modules,type=volume"
  ],
  "postCreateCommand": ".devcontainer/setup.sh",
  "forwardPorts": [3000, 3001, 4000, 4001, 5432, 7000, 7001],
  "customizations": {
    "vscode": {
      "extensions": [
        "svelte.svelte-vscode",
        "golang.go",
        "esbenp.prettier-vscode",
        "dbaeumer.vscode-eslint"
      ]
    }
  }
}
