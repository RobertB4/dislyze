{
  "components": {
    "schemas": {
      "EnterpriseFeatures": {
        "additionalProperties": false,
        "properties": {
          "ip_whitelist": {
            "$ref": "#/components/schemas/IPWhitelist"
          },
          "rbac": {
            "$ref": "#/components/schemas/RBAC"
          },
          "sso": {
            "$ref": "#/components/schemas/SSO"
          }
        },
        "type": "object"
      },
      "ErrorDetail": {
        "additionalProperties": false,
        "properties": {
          "location": {
            "description": "Where the error occurred, e.g. 'body.items[3].tags' or 'path.thing-id'",
            "type": "string"
          },
          "message": {
            "description": "Error message text",
            "type": "string"
          },
          "value": {
            "description": "The value at the given location"
          }
        },
        "type": "object"
      },
      "ErrorModel": {
        "additionalProperties": false,
        "properties": {
          "$schema": {
            "description": "A URL to the JSON Schema for this object.",
            "examples": [
              "https://example.com/schemas/ErrorModel.json"
            ],
            "format": "uri",
            "readOnly": true,
            "type": "string"
          },
          "detail": {
            "description": "A human-readable explanation specific to this occurrence of the problem.",
            "examples": [
              "Property foo is required but is missing."
            ],
            "type": "string"
          },
          "errors": {
            "description": "Optional list of individual error details",
            "items": {
              "$ref": "#/components/schemas/ErrorDetail"
            },
            "type": [
              "array",
              "null"
            ]
          },
          "instance": {
            "description": "A URI reference that identifies the specific occurrence of the problem.",
            "examples": [
              "https://example.com/error-log/abc123"
            ],
            "format": "uri",
            "type": "string"
          },
          "status": {
            "description": "HTTP status code",
            "examples": [
              400
            ],
            "format": "int64",
            "type": "integer"
          },
          "title": {
            "description": "A short, human-readable summary of the problem type. This value should not change between occurrences of the error.",
            "examples": [
              "Bad Request"
            ],
            "type": "string"
          },
          "type": {
            "default": "about:blank",
            "description": "A URI reference to human-readable documentation for the error.",
            "examples": [
              "https://example.com/errors/example"
            ],
            "format": "uri",
            "type": "string"
          }
        },
        "type": "object"
      },
      "GenerateTenantInvitationTokenRequest": {
        "additionalProperties": false,
        "properties": {
          "$schema": {
            "description": "A URL to the JSON Schema for this object.",
            "examples": [
              "https://example.com/schemas/GenerateTenantInvitationTokenRequest.json"
            ],
            "format": "uri",
            "readOnly": true,
            "type": "string"
          },
          "company_name": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "sso": {
            "$ref": "#/components/schemas/SSOConfig"
          },
          "user_name": {
            "type": "string"
          }
        },
        "required": [
          "email"
        ],
        "type": "object"
      },
      "GenerateTenantInvitationTokenResponse": {
        "additionalProperties": false,
        "properties": {
          "$schema": {
            "description": "A URL to the JSON Schema for this object.",
            "examples": [
              "https://example.com/schemas/GenerateTenantInvitationTokenResponse.json"
            ],
            "format": "uri",
            "readOnly": true,
            "type": "string"
          },
          "url": {
            "type": "string"
          }
        },
        "required": [
          "url"
        ],
        "type": "object"
      },
      "GetTenantsResponse": {
        "additionalProperties": false,
        "properties": {
          "$schema": {
            "description": "A URL to the JSON Schema for this object.",
            "examples": [
              "https://example.com/schemas/GetTenantsResponse.json"
            ],
            "format": "uri",
            "readOnly": true,
            "type": "string"
          },
          "tenants": {
            "items": {
              "$ref": "#/components/schemas/TenantResponse"
            },
            "type": [
              "array",
              "null"
            ]
          }
        },
        "required": [
          "tenants"
        ],
        "type": "object"
      },
      "GetUsersByTenantResponse": {
        "additionalProperties": false,
        "properties": {
          "$schema": {
            "description": "A URL to the JSON Schema for this object.",
            "examples": [
              "https://example.com/schemas/GetUsersByTenantResponse.json"
            ],
            "format": "uri",
            "readOnly": true,
            "type": "string"
          },
          "users": {
            "items": {
              "$ref": "#/components/schemas/UserInfo"
            },
            "type": [
              "array",
              "null"
            ]
          }
        },
        "required": [
          "users"
        ],
        "type": "object"
      },
      "IPWhitelist": {
        "additionalProperties": false,
        "properties": {
          "active": {
            "type": "boolean"
          },
          "allow_internal_admin_bypass": {
            "type": "boolean"
          },
          "enabled": {
            "type": "boolean"
          }
        },
        "type": "object"
      },
      "LoginRequestBody": {
        "additionalProperties": false,
        "properties": {
          "$schema": {
            "description": "A URL to the JSON Schema for this object.",
            "examples": [
              "https://example.com/schemas/LoginRequestBody.json"
            ],
            "format": "uri",
            "readOnly": true,
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "password": {
            "type": "string"
          }
        },
        "required": [
          "email",
          "password"
        ],
        "type": "object"
      },
      "MeResponse": {
        "additionalProperties": false,
        "properties": {
          "$schema": {
            "description": "A URL to the JSON Schema for this object.",
            "examples": [
              "https://example.com/schemas/MeResponse.json"
            ],
            "format": "uri",
            "readOnly": true,
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "tenant_name": {
            "type": "string"
          },
          "user_id": {
            "type": "string"
          },
          "user_name": {
            "type": "string"
          }
        },
        "required": [
          "tenant_name",
          "user_id",
          "email",
          "user_name"
        ],
        "type": "object"
      },
      "RBAC": {
        "additionalProperties": false,
        "properties": {
          "enabled": {
            "type": "boolean"
          }
        },
        "type": "object"
      },
      "SSO": {
        "additionalProperties": false,
        "properties": {
          "allowed_domains": {
            "items": {
              "type": "string"
            },
            "type": [
              "array",
              "null"
            ]
          },
          "attribute_mapping": {
            "additionalProperties": {
              "type": "string"
            },
            "type": "object"
          },
          "enabled": {
            "type": "boolean"
          },
          "idp_metadata_url": {
            "type": "string"
          }
        },
        "type": "object"
      },
      "SSOConfig": {
        "additionalProperties": false,
        "properties": {
          "allowed_domains": {
            "items": {
              "type": "string"
            },
            "type": [
              "array",
              "null"
            ]
          },
          "enabled": {
            "type": "boolean"
          },
          "idp_metadata_url": {
            "type": "string"
          }
        },
        "required": [
          "enabled",
          "idp_metadata_url",
          "allowed_domains"
        ],
        "type": "object"
      },
      "TenantResponse": {
        "additionalProperties": false,
        "properties": {
          "created_at": {
            "type": "string"
          },
          "enterprise_features": {
            "$ref": "#/components/schemas/EnterpriseFeatures"
          },
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "stripe_customer_id": {
            "type": "string"
          },
          "updated_at": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "name",
          "enterprise_features",
          "created_at",
          "updated_at"
        ],
        "type": "object"
      },
      "UpdateTenantRequestBody": {
        "additionalProperties": false,
        "properties": {
          "$schema": {
            "description": "A URL to the JSON Schema for this object.",
            "examples": [
              "https://example.com/schemas/UpdateTenantRequestBody.json"
            ],
            "format": "uri",
            "readOnly": true,
            "type": "string"
          },
          "enterprise_features": {
            "$ref": "#/components/schemas/EnterpriseFeatures"
          },
          "name": {
            "type": "string"
          }
        },
        "required": [
